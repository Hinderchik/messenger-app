{
  "routes": [
    {
      "src": "/app.js",
      "dest": "/app.js",
      "headers": {
        "Content-Type": "application/javascript"
      }
    },
    {
      "src": "/style.css",
      "dest": "/style.css",
      "headers": {
        "Content-Type": "text/css"
      }
    },
    {
      "src": "/(.*\\.html)",
      "dest": "/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ]
}
