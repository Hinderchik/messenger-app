{
  "routes": [
    { "src": "/api/auth", "dest": "/api/auth.js" },
    { "src": "/api/ping", "dest": "/api/ping.js" },
    { "src": "/api/core", "dest": "/api/core.js" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/(.*\\.css)", "dest": "/$1" },
    { "src": "/(.*\\.js)", "dest": "/$1" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ]
}
